; Engine configuration file.
; Godot 4.4 project for First 2D Jump-and-Run.

config_version=5

[application]

config/name="First 2D Jump-and-Run"
config/description="A child-friendly 2D jump-and-run game."
config/version="1.3.28"
run/main_scene="res://scenes/ui/startup_loading.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.png"
boot_splash/bg_color=Color(0.9, 0.48, 0.2, 1)
boot_splash/image="res://assets/world/transition_desert_skyline.png"
boot_splash/fullsize=true
boot_splash/use_filter=true
boot_splash/minimum_display_time=1200

[audio]

general/text_to_speech=true

[autoload]

InputBindings="*res://scripts/autoload/input_bindings.gd"
InputManager="*res://scripts/autoload/input_manager.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
Narrator="*res://scripts/autoload/narrator.gd"
DebugLabels="*res://scripts/autoload/debug_labels.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[internationalization]

locale/fallback="de"
locale/translations=PackedStringArray("res://assets/i18n/game_text.en.translation", "res://assets/i18n/game_text.de.translation")

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
